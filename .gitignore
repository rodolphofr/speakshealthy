```gitignore
############################################
# Compiled class files
############################################
*.class

############################################
# Logs
############################################
*.log
logs/
log/
*.out

############################################
# Maven
############################################
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties

############################################
# Gradle
############################################
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar

############################################
# IntelliJ IDEA
############################################
.idea/
*.iws
*.iml
*.ipr
out/

############################################
# Eclipse
############################################
.project
.classpath
.settings/
.springBeans
.sts4-cache/

############################################
# VS Code
############################################
.vscode/

############################################
# NetBeans
############################################
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

############################################
# MacOS
############################################
.DS_Store

############################################
# Windows
############################################
Thumbs.db
ehthumbs.db
Desktop.ini

############################################
# Linux
############################################
*~

############################################
# Environment Variables
############################################
.env
.env.*
application-local.yml
application-local.properties
application-dev.yml
application-dev.properties

############################################
# Spring Boot
############################################
*.jar
*.war
*.ear
spring.log

############################################
# Temporary files
############################################
tmp/
temp/
*.tmp
*.swp

############################################
# Coverage / Reports
############################################
coverage/
jacoco.exec
/site/
reports/

############################################
# SonarQube
############################################
.sonar/
.scannerwork/

############################################
# Node (if frontend exists)
############################################
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

############################################
# Docker
############################################
docker-compose.override.yml

############################################
# Kubernetes
############################################
*.kubeconfig

############################################
# Secrets / Certificates
############################################
*.pem
*.key
*.crt
*.p12
*.jks
*.keystore

############################################
# OS generated files
############################################
Icon?
._*

############################################
# Hibernate
############################################
hibernate.log

############################################
# Testcontainers
############################################
.testcontainers.properties

############################################
# Generated files
############################################
generated/
bin/

############################################
# Backup files
############################################
*.bak
*.backup
*.old

############################################
# Editor swap files
############################################
*.swo
*.swn

############################################
# Archive files
############################################
*.zip
*.tar
*.tar.gz
*.rar
```
